# Telegram уведомления (опционально)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# DNS Shop API
API_BASE_URL=https://www.dns-shop.ru

# Куки города для автоматического подставления в браузер
CITY_COOKIE_PATH=moscow
CITY_COOKIE_CURRENT=c5f58b981d1ed0bad05ae63f54072ea9dcdf57ac......

# База данных
DB_PATH=dns_monitor.db

# Интервал парсинга (в секундах, 3600 = 1 час)
PARSE_INTERVAL=3600

# Переподключения при ошибках
MAX_RETRIES=4
RETRY_DELAY=5.0

# Резервные учётные данные DNS (опционально, если куки вычеркнут)
DNS_LOGIN=
DNS_PASSWORD=

# Chrome опции (опционально)
# CHROME_HEADLESS=false
# CHROME_PROFILE_DIR=

# Логирование и отладка
# LOG_LEVEL=INFO  # Уровни: DEBUG, INFO, WARNING, ERROR
# Установите DEBUG для подробных логов включая HTTP запросы

# Кроссплатформенность
# USE_PLATFORM_UA=false  # По умолчанию используется Windows UA для совместимости
# Установите true если хотите использовать реальный UserAgent вашей платформы (Linux/macOS)
