# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ADMIN=
TELEGRAM_CHAT_ID=

# DNS Shop API
API_BASE_URL=https://www.dns-shop.ru

# Database
DB_PATH=dns_monitor.db

# Parser loop
PARSE_INTERVAL=3600
PARSE_CONCURRENCY=5

# Retries
MAX_RETRIES=4
RETRY_DELAY=5.0

# Logging
LOG_LEVEL=INFO

# Qrator / Node timeouts
QRATOR_INIT_TIMEOUT=360
QRATOR_NODE_TIMEOUT=300
QRATOR_PROXY_CHECK_TIMEOUT=20

# Use real OS User-Agent (false = Windows UA for compatibility)
USE_PLATFORM_UA=false

# Proxy (optional)
PROXY_HOST=
PROXY_PORT=0
PROXY_USER=
PROXY_PASSWORD=
