# Telegram уведомления (опционально)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# DNS Shop API
API_BASE_URL=https://www.dns-shop.ru

# Город и его куки
CITY_ID=884019c7-cf52-11de......
CITY_NAME=Москва

# Куки города для автоматического подставления в браузер
CITY_COOKIE_PATH=moscow
CITY_COOKIE_CURRENT=c5f58b981d1ed0bad05ae63f54072ea9dcdf57ac......

# База данных
DB_PATH=dns_monitor.db

# Интервал парсинга (в секундах, 3600 = 1 час)
PARSE_INTERVAL=3600

# Переподключения при ошибках
MAX_RETRIES=4
RETRY_DELAY=5.0

# Резервные учётные данные DNS (опционально, если куки вычеркнут)
DNS_LOGIN=
DNS_PASSWORD=

# Chrome опции (опционально)
# CHROME_HEADLESS=false
# CHROME_PROFILE_DIR=

# Логирование и отладка
# LOG_LEVEL=INFO  # Уровни: DEBUG, INFO, WARNING, ERROR
# Установите DEBUG для подробных логов включая HTTP запросы

# Кроссплатформенность
# USE_PLATFORM_UA=false  # По умолчанию используется Windows UA для совместимости
# Установите true если хотите использовать реальный UserAgent вашей платформы (Linux/macOS)

# --- solve_qrator.js (Playwright) ---
# На Linux-сервере без этих переменных Qrator отдаёт 403 на /__qrator/validate
# (bundled Chromium-for-Testing палится по JA3/H2 fingerprint).
# Решение: использовать настоящий google-chrome-stable БЕЗ stealth-плагина.
#
# Установка Chrome на сервер (один раз):
#   wget -qO- https://dl.google.com/linux/linux_signing_key.pub | apt-key add -
#   echo "deb [arch=amd64] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list
#   apt-get update && apt-get install -y google-chrome-stable
#
# На Windows можно не задавать — дефолты работают (bundled Chromium + без stealth).
QRATOR_CHANNEL=chrome
QRATOR_STEALTH=0
# QRATOR_HEADLESS: не задано = авто (new на linux, классический на win/mac)
#                  false = headful (тогда запускать через: xvfb-run -a python main.py)
